GIT_USER=Your Name
GIT_EMAIL=you@example.com
# Path to your code folder on the host — will be mounted at /gc inside the container.
FOLDER=/home/you/code
# Fine-grained GitHub PAT — scope to only the repos GC needs.
# Permissions needed: Contents (read/write), Pull requests (write).
# Create at: https://github.com/settings/tokens?type=beta
# DO NOT use your main GitHub token here.
GH_TOKEN=github_pat_xxx
